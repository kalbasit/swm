{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "automerge": false,
  "schedule": ["on monday"],
  "labels": ["dependencies", "renovate"],
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "One PR per Go module — no cross-module grouping",
      "matchManagers": ["gomod"],
      "groupName": null
    },
    {
      "description": "One PR per Nix flake input — no cross-input grouping",
      "matchManagers": ["nix"],
      "groupName": null
    }
  ]
}
